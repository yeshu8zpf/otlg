      "datatype": "xsd:string"
    },
    {
      "property": "organization_address",
      "belongsToClassMap": "Organization",
      "column": "organizations.Address",
      "datatype": "xsd:string",
      "condition": [
        "organizations.Address IS NOT NULL"
      ]
    },
    {
      "property": "organization_location",
      "belongsToClassMap": "Organization",
