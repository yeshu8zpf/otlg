{
  "classes": [
    {
      "class": "Conference",
      "name": "Conference",
      "id": "conference/@@conferences.confid@@"
    },
    {
      "class": "Organization",
      "name": "Organization",
      "id": "organization/@@organizations.orgid@@"
    },
    {
      "class": "Paper",
      "name": "Paper",
      "id": "paper/@@papers.paperid@@"
    },
    {
      "class": "Person",
      "name": "Person",
      "id": "person/@@persons.perid@@"
    },
    {
      "class": "Topic",
      "name": "Topic",
      "id": "topic/@@topics.topicid@@"
    },
    {
      "class": "FullProfessor",
      "name": "FullProfessor",
      "id": "person/@@persons.perid@@",
      "condition": [
        "persons.Type = 'Full_Professor'"
      ],
      "subClassOf": [
        "Class:Person"
      ]
    },
    {
      "class": "Researcher",
      "name": "Researcher",
      "id": "person/@@persons.perid@@",
      "condition": [
        "persons.Type = 'Researcher'"
      ],
      "subClassOf": [
        "Class:Person"
      ]
    }
  ],
  "object_properties": [
    {
      "property": "paper_presented_at_conference",
      "belongsToClassMap": "Paper",
      "refersToClassMap": "Conference",
      "join": [
        "papers.Conference = conferences.ConfID"
      ],
      "condition": [
        "papers.Conference IS NOT NULL"
      ]
    },
    {
      "property": "paper_has_topic",
      "belongsToClassMap": "Paper",
      "refersToClassMap": "Topic",
      "join": [
        "rel_paper_topic.PaperID = papers.PaperID",
        "rel_paper_topic.TopicID = topics.TopicID"
      ]
    },
    {
      "property": "person_affiliated_with_organization",
      "belongsToClassMap": "Person",
      "refersToClassMap": "Organization",
      "join": [
        "rel_person_organization.PersonID = persons.PerID",
        "rel_person_organization.OrganizationID = organizations.OrgID"
      ]
    },
    {
      "property": "person_author_of_paper",
      "belongsToClassMap": "Person",
      "refersToClassMap": "Paper",
      "join": [
        "rel_person_paper.PersonID = persons.PerID",
        "rel_person_paper.PaperID = papers.PaperID"
      ]
    },
    {
      "property": "person_has_topic",
      "belongsToClassMap": "Person",
      "refersToClassMap": "Topic",
      "join": [
        "rel_person_topic.PersonID = persons.PerID",
        "rel_person_topic.TopicID = topics.TopicID"
      ]
    },
    {
      "property": "organization_belongs_to_organization",
      "belongsToClassMap": "Organization",
      "refersToClassMap": "Organization",
      "join": [
        "organizations.Belongsto = organizations.OrgID"
      ],
      "condition": [
        "organizations.Belongsto IS NOT NULL"
      ]
    },
    {
      "property": "topic_broader_topic",
      "belongsToClassMap": "Topic",
      "refersToClassMap": "Topic",
      "join": [
        "topics.ParentID = topics.TopicID"
      ],
      "condition": [
        "topics.ParentID IS NOT NULL"
      ]
    }
  ],
  "data_properties": [
    {
      "property": "conference_name",
      "belongsToClassMap": "Conference",
      "column": "conferences.Name",
      "datatype": "xsd:string"
    },
    {
      "property": "conference_URI",
      "belongsToClassMap": "Conference",
      "column": "conferences.URI",
      "datatype": "xsd:anyURI",
      "condition": [
        "conferences.URI IS NOT NULL"
      ]
    },
    {
      "property": "conference_date_text",
      "belongsToClassMap": "Conference",
      "column": "conferences.Date",
      "datatype": "xsd:string"
    },
    {
      "property": "conference_location",
      "belongsToClassMap": "Conference",
      "column": "conferences.Location",
      "datatype": "xsd:string"
    },
    {
      "property": "conference_timestamp",
      "belongsToClassMap": "Conference",
      "column": "conferences.Datum",
      "datatype": "xsd:dateTime",
      "condition": [
        "conferences.Datum IS NOT NULL"
      ]
    },
    {
      "property": "organization_type_literal",
      "belongsToClassMap": "Organization",
      "column": "organizations.Type",
      "datatype": "xsd:string",
      "condition": [
        "organizations.Type IS NOT NULL"
      ]
    },
    {
      "property": "organization_name",
      "belongsToClassMap": "Organization",
