      "datatype": "xsd:string",
      "condition": [
        "organizations.Location IS NOT NULL"
      ]
    },
    {
      "property": "organization_postcode",
      "belongsToClassMap": "Organization",
      "column": "organizations.Postcode",
      "datatype": "xsd:string",
      "condition": [
        "organizations.Postcode IS NOT NULL"
      ]
    },
    {
      "property": "organization_country",
      "belongsToClassMap": "Organization",
      "column": "organizations.Country",
      "datatype": "xsd:string",
      "condition": [
        "organizations.Country IS NOT NULL"
      ]
    },
    {
      "property": "organization_URI",
      "belongsToClassMap": "Organization",
      "column": "organizations.URI",
      "datatype": "xsd:anyURI",
      "condition": [
        "organizations.URI IS NOT NULL"
      ]
    },
    {
      "property": "organization_homepage",
      "belongsToClassMap": "Organization",
      "column": "organizations.Homepage",
      "datatype": "xsd:anyURI",
      "condition": [
        "organizations.Homepage IS NOT NULL"
      ]
    },
    {
      "property": "paper_title",
      "belongsToClassMap": "Paper",
      "column": "papers.Title",
      "datatype": "xsd:string"
    },
    {
      "property": "paper_abstract",
      "belongsToClassMap": "Paper",
      "column": "papers.Abstract",
      "datatype": "xsd:string",
      "condition": [
        "papers.Abstract IS NOT NULL"
      ]
    },
    {
      "property": "paper_URI",
      "belongsToClassMap": "Paper",
      "column": "papers.URI",
      "datatype": "xsd:anyURI",
      "condition": [
        "papers.URI IS NOT NULL"
      ]
    },
    {
      "property": "paper_year",
      "belongsToClassMap": "Paper",
      "column": "papers.Year",
      "datatype": "xsd:integer",
      "condition": [
        "papers.Year IS NOT NULL"
      ]
    },
    {
      "property": "paper_publish_flag",
      "belongsToClassMap": "Paper",
      "column": "papers.Publish",
      "datatype": "xsd:integer",
      "condition": [
        "papers.Publish IS NOT NULL"
      ]
    },
    {
      "property": "person_type_literal",
      "belongsToClassMap": "Person",
      "column": "persons.Type",
      "datatype": "xsd:string",
      "condition": [
        "persons.Type IS NOT NULL"
      ]
    },
    {
      "property": "person_first_name",
      "belongsToClassMap": "Person",
