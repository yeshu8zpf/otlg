{
  "classes": [
    {
      "id": "conference/{ConfID}",
      "class": "Conference",
      "name": "Conference"
    },
    {
      "id": "organization/{OrgID}",
      "class": "Organization",
      "name": "Organization"
    },
    {
      "id": "paper/{PaperID}",
      "class": "Paper",
      "name": "Paper"
    },
    {
      "id": "person/{PerID}",
      "class": "Person",
      "name": "Person"
    },
    {
      "id": "topic/{TopicID}",
      "class": "Topic",
      "name": "Topic"
    },
    {
      "id": "paper-topic-relation/{PaperID}-{TopicID}",
      "class": "PaperTopicRelation",
      "name": "PaperTopicRelation"
    }
  ],
  "object_properties": [
    {
      "property": "paper_presented_at_conference",
      "belongsToClassMap": "Paper",
      "refersToClassMap": "Conference",
      "join": [
        "papers.Conference = conferences.ConfID"
      ]
    },
    {
      "property": "organization_part_of_organization",
      "belongsToClassMap": "Organization",
      "refersToClassMap": "Organization",
      "join": [
        "organizations.Belongsto = organizations.OrgID"
      ]
    },
    {
      "property": "person_affiliated_with_organization",
      "belongsToClassMap": "Person",
      "refersToClassMap": "Organization",
      "join": [
        "persons.PerID = rel_person_organization.PersonID",
        "rel_person_organization.OrganizationID = organizations.OrgID"
      ]
    },
    {
      "property": "person_author_of_paper",
      "belongsToClassMap": "Person",
      "refersToClassMap": "Paper",
      "join": [
        "persons.PerID = rel_person_paper.PersonID",
        "rel_person_paper.PaperID = papers.PaperID"
      ]
    },
    {
      "property": "person_interested_in_topic",
      "belongsToClassMap": "Person",
      "refersToClassMap": "Topic",
      "join": [
        "persons.PerID = rel_person_topic.PersonID",
        "rel_person_topic.TopicID = topics.TopicID"
      ]
    },
    {
      "property": "topic_broader_topic",
      "belongsToClassMap": "Topic",
      "refersToClassMap": "Topic",
      "join": [
        "topics.ParentID = topics.TopicID"
      ]
    },
    {
      "property": "paper_topic_relation_paper",
      "belongsToClassMap": "PaperTopicRelation",
      "refersToClassMap": "Paper",
      "join": [
        "rel_paper_topic.PaperID = papers.PaperID"
      ]
    },
    {
      "property": "paper_topic_relation_topic",
      "belongsToClassMap": "PaperTopicRelation",
      "refersToClassMap": "Topic",
      "join": [
        "rel_paper_topic.TopicID = topics.TopicID"
      ]
    }
  ],
