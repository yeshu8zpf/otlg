map:wellbore_development_all__wlbCompletionDate
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_development_all ;
    d2rq:column "wellbore_development_all.wlbcompletiondate" ;
    d2rq:condition "wellbore_development_all.wlbcompletiondate <> ''", "wellbore_development_all.wlbcompletiondate <> '9999-12-31t00:00:00'" ;
    d2rq:datatype xsd:dateTime ;
    d2rq:property npdv:dateWellboreCompletion ;
    d2rq:propertyDefinitionComment "the date when the anchor handling started. in case of jack-ups, the completion date is the date the jacking-down started." ;
    d2rq:propertyDefinitionLabel "completion date" .

map:wellbore_development_all__wlbCompletionYear
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_development_all ;
    d2rq:column "wellbore_development_all.wlbcompletionyear" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:wellboreCompletionYear ;
    d2rq:propertyDefinitionComment "the year when the anchor handling started. in case of jack-ups: the year the jacking-down started." ;
    d2rq:propertyDefinitionLabel "completion year" .

map:wellbore_development_all__wlbContent
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_development_all ;
    d2rq:column "wellbore_development_all.wlbcontent" ;

    d2rq:datatype xsd:string ;
    d2rq:property npdv:wellboreContent ;
    d2rq:propertyDefinitionComment "for exploration wellbores, status of discovery. examples of legal values: dry, shows (trace amounts of hydrocarbons), gas, gas/condensate, oil or oil/gas. shows (gas shows, oil shows or oil/gas shows) are detected as fluorescent cut (organic extract), petroleum odour, or visual stain on cuttings or cores, or as increased gas reading on the mud-loggers gas detection equipment. for development wellbores, type of produced/injected fluid. examples of legal values: water, cuttings, not available, oil, gas/condensate, oil/gas, co2, gas, water/gas, not applicable. " ;
    d2rq:propertyDefinitionLabel "content" .

map:wellbore_development_all__wlbContentPlanned
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_development_all ;
    d2rq:column "wellbore_development_all.wlbcontentplanned" ;

    d2rq:datatype xsd:string ;
    d2rq:property npdv:wellborePlannedContent ;
    d2rq:propertyDefinitionComment "only relevant for development wellbores, planned type of produced or injected fluid. examples of legal values: co2, cuttings, gas, not applicable, not available, water, water/gas" ;
    d2rq:propertyDefinitionLabel "content - planned" .

map:wellbore_development_all__wlbDateUpdated
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_development_all ;
    d2rq:column "wellbore_development_all.wlbdateupdated" ;
    d2rq:condition "wellbore_development_all.wlbdateupdated <> ''", "wellbore_development_all.wlbdateupdated <> '9999-12-31t00:00:00'" ;
    d2rq:datatype xsd:dateTime ;
    d2rq:property npdv:dateUpdated ;
    d2rq:propertyDefinitionComment "date when information about this wellbore was last updated or inserted for the first time.the date will only be changed if the data in the 'main level' in the tab 'wellbore' will be changed." ;
    d2rq:propertyDefinitionLabel "date main level updated" .

map:wellbore_development_all__wlbDateUpdatedMax
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_development_all ;
    d2rq:column "wellbore_development_all.wlbdateupdatedmax" ;
    d2rq:condition "wellbore_development_all.wlbdateupdatedmax <> ''", "wellbore_development_all.wlbdateupdatedmax <> '9999-12-31t00:00:00'" ;
    d2rq:datatype xsd:dateTime ;
    d2rq:property npdv:dateUpdatedMax ;
    d2rq:propertyDefinitionComment "date when any information about this wellbore was last updated or inserted for the first time. the date also will bli change if some of the data in the 'sub levels' in the tab 'wellbore' will be changed." ;
    d2rq:propertyDefinitionLabel "date all updated" .

