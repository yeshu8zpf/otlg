    d2rq:propertyDefinitionLabel "wellbore name, part 2" .

map:wellbore_development_all__wlbNamePart3
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_development_all ;
    d2rq:column "wellbore_development_all.wlbnamepart3" ;

    d2rq:datatype xsd:string ;
    d2rq:property npdv:wellboreNamePart3 ;
    d2rq:propertyDefinitionComment "part 3 of the wellbore name. tells the name of the installation the wellbore was drilled from. not used for exploration wellbores. based on npd guidelines for designation of wells and wellbores." ;
    d2rq:propertyDefinitionLabel "wellbore name, part 3" .

map:wellbore_development_all__wlbNamePart4
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_development_all ;
    d2rq:column "wellbore_development_all.wlbnamepart4" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:wellboreNamePart4 ;
    d2rq:propertyDefinitionComment "part 4 of the wellbore name. serial number for the wellbore. based on npd guidelines for designation of wells and wellbores." ;
    d2rq:propertyDefinitionLabel "wellbore name, part 4" .

map:wellbore_development_all__wlbNamePart5
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_development_all ;
    d2rq:column "wellbore_development_all.wlbnamepart5" ;

    d2rq:datatype xsd:string ;
    d2rq:property npdv:wellboreNamePart5 ;
    d2rq:propertyDefinitionComment "part 5 of the wellbore name. used to indicate exploration wells planned deviated (s), sidetracks (a, b,...), re-entries (r) or planned multilaterals (y). based on npd guidelines for designation of wells and wellbores." ;
    d2rq:propertyDefinitionLabel "wellbore name, part 5" .

map:wellbore_development_all__wlbNamePart6
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_development_all ;
    d2rq:column "wellbore_development_all.wlbnamepart6" ;

    d2rq:datatype xsd:string ;
