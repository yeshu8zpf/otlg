map:strat_litho_wellbore
    a d2rq:ClassMap ;
    rdfs:label "npdv:wellborestratum__strat_litho_wellbore" ;
    d2rq:class npdv:WellboreStratum ;
    d2rq:classDefinitionComment "lithostratigraphic units (groups, formations and members) on the norwegian continental shelf. exploration wellbores penetrating a particular unit." ;
    d2rq:classDefinitionLabel "stratigraphy: wellbores" ;
    d2rq:dataStorage map:Adatabase ;
    d2rq:uriPattern "http://sws.ifi.uio.no/data/npd-v2/wellbore/@@strat_litho_wellbore.wlbnpdidwellbore@@/stratum/@@strat_litho_wellbore.lsunpdidlithostrat@@/depth/@@strat_litho_wellbore.lsutopdepth@@/@@strat_litho_wellbore.lsubottomdepth@@" .

map:strat_litho_wellbore__dateSyncNPD
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:strat_litho_wellbore ;
    d2rq:column "strat_litho_wellbore.datesyncnpd" ;
    d2rq:condition "strat_litho_wellbore.datesyncnpd <> ''", "strat_litho_wellbore.datesyncnpd <> '9999-12-31t00:00:00'" ;
    d2rq:datatype xsd:dateTime ;
    d2rq:property npdv:dateSyncNPD .

map:strat_litho_wellbore__lsuBottomDepth
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:strat_litho_wellbore ;
    d2rq:column "strat_litho_wellbore.lsubottomdepth" ;

    d2rq:datatype xsd:decimal ;
    d2rq:property npdv:wellboreStratumBottomDepth ;
    d2rq:propertyDefinitionComment "depth in meters to the bottom of the lithostratigraphic unit." ;
    d2rq:propertyDefinitionLabel "bottom depth [m]" .

map:strat_litho_wellbore__lsuNpdidLithoStrat
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:strat_litho_wellbore ;
    d2rq:property npdv:inLithostratigraphicUnit ;
    d2rq:propertyDefinitionComment "npd's unique id for lithostratigraphic units." ;
    d2rq:propertyDefinitionLabel "npdid lithostrat. unit" ;
    d2rq:uriPattern "http://sws.ifi.uio.no/data/npd-v2/stratum/@@strat_litho_wellbore.lsunpdidlithostrat@@" .

map:strat_litho_wellbore__lsuTopDepth
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:strat_litho_wellbore ;
    d2rq:column "strat_litho_wellbore.lsutopdepth" ;

    d2rq:datatype xsd:decimal ;
    d2rq:property npdv:wellboreStratumTopDepth ;
    d2rq:propertyDefinitionComment "measured length along the wellbore from kelly bushing to start of lithostratigraphic unit. always the group/formation/member which the bit goes into. note that in some situations, for example highly deviated wells, faults, drilling beyond salt walls, this might not be a true stratigraphic top. the start of a unit will be its stratigraphic base when drilled from underneath. in case of intercalating formations several top depths may occur for the same formation designating the top depths of the sub-packages. for some intervals in some wells only groups are interpreted and no formation tops have been assigned. members have been assigned only near the type well area. in some cases informal names have been used for formations that are not described in the official nomenclature yet. these are marked with . npd interpretations. may be subject to changes." ;
    d2rq:propertyDefinitionLabel "top depth [m]" .

map:strat_litho_wellbore__wlbNpdidWellbore__ref
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:strat_litho_wellbore ;
    d2rq:join "strat_litho_wellbore.wlbnpdidwellbore => wellbore_npdid_overview.wlbnpdidwellbore" ;
    d2rq:property npdv:stratumForWellbore ;
    d2rq:refersToClassMap map:wellbore_npdid_overview .

