    d2rq:datatype xsd:decimal ;
    d2rq:property npdv:decimalDegreesNS ;
    d2rq:propertyDefinitionComment "geographic coordinate of the wellhead, north-south, decimal degrees." ;
    d2rq:propertyDefinitionLabel "ns decimal degrees" .

map:wellbore_exploration_all__wlbNsDeg
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbnsdeg" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:degreesNS ;
    d2rq:propertyDefinitionComment "geographic coordinate of the wellhead, north-south degrees." ;
    d2rq:propertyDefinitionLabel "ns degrees" .

map:wellbore_exploration_all__wlbNsMin
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbnsmin" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:minutesNS ;
    d2rq:propertyDefinitionComment "geographic coordinate of the wellhead, north-south minutes." ;
    d2rq:propertyDefinitionLabel "ns minutes" .

map:wellbore_exploration_all__wlbNsSec
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbnssec" ;

    d2rq:datatype xsd:decimal ;
    d2rq:property npdv:secondsNS ;
    d2rq:propertyDefinitionComment "geographic coordinate of the wellhead, north-south seconds (decimal number)." ;
    d2rq:propertyDefinitionLabel "ns seconds" .

map:wellbore_exploration_all__wlbNsUtm
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbnsutm" ;

    d2rq:datatype xsd:decimal ;
    d2rq:property npdv:utmNS ;
    d2rq:propertyDefinitionComment "universal transverse mercator coordinate of the wellhead, north-south." ;
    d2rq:propertyDefinitionLabel "ns utm [m]" .

map:wellbore_exploration_all__wlbPlotSymbol
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbplotsymbol" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:wellborePlotSymbol ;
    d2rq:propertyDefinitionComment "npd's plot symbol number for wellbores." ;
    d2rq:propertyDefinitionLabel "plot symbol" .

map:wellbore_exploration_all__wlbPressReleaseUrl
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:property npdv:pressReleaseURL ;
    d2rq:uriColumn "wellbore_exploration_all.wlbpressreleaseurl" .

map:wellbore_exploration_all__wlbProductionLicence__ref
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:join "wellbore_exploration_all.wlbproductionlicence => licence.prlname" ;
    d2rq:property npdv:explorationWellboreForLicence ;
    d2rq:refersToClassMap map:licence .

map:wellbore_exploration_all__wlbPurpose
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbpurpose" ;

    d2rq:datatype xsd:string ;
    d2rq:property npdv:wellborePurpose ;
    d2rq:propertyDefinitionComment "post-drill classification of the wellbore. legal values for exploration wellbores: wildcat, appraisal. example of legal values for development wellbores: observation, not available, production, injection. " ;
    d2rq:propertyDefinitionLabel "purpose" .

map:wellbore_exploration_all__wlbPurposePlanned
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbpurposeplanned" ;

    d2rq:datatype xsd:string ;
    d2rq:property npdv:wellborePlannedPurpose ;
    d2rq:propertyDefinitionComment "pre-drill purpose of the wellbore. legal values for exploration wellbores: wildcat, appraisal. example of legal values for development wellbores: observation, not available, production, injection." ;
    d2rq:propertyDefinitionLabel "purpose - planned" .

map:wellbore_exploration_all__wlbPurpose__Class
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:property rdf:type ;
    d2rq:translateWith map:tt__wellbore_exploration_all__wlbPurpose__Class ;
    d2rq:uriColumn "wellbore_exploration_all.wlbpurpose" .

