map:facility_fixed_belongsTo_facility
    a d2rq:PropertyBridge ;
    d2rq:alias "facility_fixed as facility_fixed2" ;
    d2rq:belongsToClassMap map:facility_fixed ;
    d2rq:condition "facility_fixed.fclbelongstokind = 'tuf' or facility_fixed.fclbelongstokind = 'tuf part'" ;
    d2rq:join "facility_fixed.fclbelongstos => facility_fixed2.fclnpdidfacility" ;
    d2rq:property npdv:belongsTo ;
    d2rq:refersToClassMap map:facility_fixed .

map:facility_fixed_belongsTo_field
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:facility_fixed ;
    d2rq:condition "facility_fixed.fclbelongstokind = 'field'" ;
    d2rq:join "facility_fixed.fclbelongstos => field.fldnpdidfield" ;
    d2rq:property npdv:belongsTo ;
    d2rq:refersToClassMap map:field .

