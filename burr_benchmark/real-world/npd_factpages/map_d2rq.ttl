map:wellbore_exploration_all__wlbAgeAtTd
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:property npdv:wellboreAgeTD ;
    d2rq:propertyDefinitionComment "age (according to geologic time scale 2004 by f. m. gradstein, et al. (2004)) of the oldest penetrated formation. may differ from age at td for example in deviated wellbores. examples of legal values: cretaceous, early cretaceous, late jurassic, early permian, early triassic, eocene." ;
    d2rq:propertyDefinitionLabel "oldest penetrated age" ;
    d2rq:uriColumn "wellbore_exploration_all.wlbageattd" .

map:wellbore_exploration_all__wlbAgeWithHc1
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:property npdv:wellboreAgeHcLevel1 ;
    d2rq:propertyDefinitionComment "age of lithostratigraphic unit, 1st level, where hydrocarbons were encountered. examples of legal values: cretaceous, early cretaceous, late jurassic, eocene. see also npd bulletins." ;
    d2rq:propertyDefinitionLabel "1st level with hc, age" ;
    d2rq:uriColumn "wellbore_exploration_all.wlbagewithhc1" .

map:wellbore_exploration_all__wlbAgeWithHc2
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:property npdv:wellboreAgeHcLevel2 ;
    d2rq:propertyDefinitionComment "age of lithostratigraphic unit, 2nd level, where hydrocarbons were encountered. examples of legal values: cretaceous, early cretaceous, late jurassic, eocene." ;
    d2rq:propertyDefinitionLabel "2nd level with hc, age" ;
    d2rq:uriColumn "wellbore_exploration_all.wlbagewithhc2" .

map:wellbore_exploration_all__wlbAgeWithHc3
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:property npdv:wellboreAgeHcLevel3 ;
    d2rq:propertyDefinitionComment "age of lithostratigraphic unit, 3rd level, where hydrocarbons were encountered. examples of legal values: cretaceous, early cretaceous, late jurassic, eocene." ;
    d2rq:propertyDefinitionLabel "3rd level with hc, age" ;
    d2rq:uriColumn "wellbore_exploration_all.wlbagewithhc3" .

