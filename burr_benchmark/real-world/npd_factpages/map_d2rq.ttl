    d2rq:propertyDefinitionComment "part 5 of the wellbore name. used to indicate exploration wells planned deviated (s), sidetracks (a, b,...), re-entries (r) or planned multilaterals (y). based on npd guidelines for designation of wells and wellbores." ;
    d2rq:propertyDefinitionLabel "wellbore name, part 5" .

map:wellbore_shallow_all__wlbNamePart6
    a d2rq:PropertyBridge ;
