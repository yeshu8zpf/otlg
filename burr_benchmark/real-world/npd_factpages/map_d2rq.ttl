map:wellbore_exploration_all__wlbEntryDate
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbentrydate" ;
    d2rq:condition "wellbore_exploration_all.wlbentrydate <> ''", "wellbore_exploration_all.wlbentrydate <> '9999-12-31t00:00:00'" ;
    d2rq:datatype xsd:dateTime ;
    d2rq:property npdv:dateWellboreEntry ;
    d2rq:propertyDefinitionComment "the date when the drill bit penetrated the earth's crust / sea floor." ;
    d2rq:propertyDefinitionLabel "entry date" .

map:wellbore_exploration_all__wlbEntryYear
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbentryyear" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:wellboreEntryYear ;
    d2rq:propertyDefinitionComment "the year when the drill bit penetrated the earth's crust / sea floor." ;
    d2rq:propertyDefinitionLabel "entry year" .

map:wellbore_exploration_all__wlbEwCode
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbewcode" ;

    d2rq:property npdv:codeEW ;
    d2rq:propertyDefinitionComment "indicator which tells if the coordinate of the wellhead is on the eastern or western hemisphere. legal values: e, w." ;
    d2rq:propertyDefinitionLabel "ew code" .

map:wellbore_exploration_all__wlbEwDeg
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbewdeg" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:degreesEW ;
    d2rq:propertyDefinitionComment "geographic coordinate of the wellhead, east-west degrees." ;
    d2rq:propertyDefinitionLabel "ew degrees" .

map:wellbore_exploration_all__wlbEwDesDeg
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbewdesdeg" ;

    d2rq:datatype xsd:decimal ;
    d2rq:property npdv:decimalDegreesEW ;
    d2rq:propertyDefinitionComment "geographic coordinate of the wellhead, east-west, decimal degrees." ;
    d2rq:propertyDefinitionLabel "ew decimal degrees" .

map:wellbore_exploration_all__wlbEwMin
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbewmin" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:minutesEW ;
    d2rq:propertyDefinitionComment "geographic coordinate of the wellhead, east-west minutes." ;
    d2rq:propertyDefinitionLabel "ew minutes" .

map:wellbore_exploration_all__wlbEwSec
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbewsec" ;

    d2rq:datatype xsd:decimal ;
    d2rq:property npdv:secondsEW ;
    d2rq:propertyDefinitionComment "geographic coordinate of the wellhead, east-west seconds (decimal number)." ;
    d2rq:propertyDefinitionLabel "ew seconds" .

map:wellbore_exploration_all__wlbEwUtm
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbewutm" ;

    d2rq:datatype xsd:decimal ;
    d2rq:property npdv:utmEW ;
    d2rq:propertyDefinitionComment "universal transverse mercator coordinate of the wellhead, east-west." ;
    d2rq:propertyDefinitionLabel "ew utm [m]" .

map:wellbore_exploration_all__wlbFactMapUrl
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:property npdv:factMapURL ;
    d2rq:propertyDefinitionComment "url to the wellbores's factmap on npd's factweb." ;
    d2rq:propertyDefinitionLabel "factmap url" ;
    d2rq:uriColumn "wellbore_exploration_all.wlbfactmapurl" .

map:wellbore_exploration_all__wlbFactPageUrl
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:property npdv:factPageURL ;
    d2rq:propertyDefinitionComment "url to the wellbores's factpage on npd's factweb." ;
    d2rq:propertyDefinitionLabel "factpage url" ;
    d2rq:uriColumn "wellbore_exploration_all.wlbfactpageurl" .

map:wellbore_exploration_all__wlbFinalVerticalDepth
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbfinalverticaldepth" ;

    d2rq:datatype xsd:decimal ;
    d2rq:property npdv:wellboreFinalVerticalDepth ;
    d2rq:propertyDefinitionComment "vertical elevation from total depth to kelly bushing. often referred to as true vertical depth (tvd)." ;
    d2rq:propertyDefinitionLabel "final vertical depth (tvd) [m rkb]" .

map:wellbore_exploration_all__wlbFormationAtTd
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:join "wellbore_exploration_all.wlbformationattd => wellbore_formation_top.lsuname" ;
    d2rq:property npdv:wellboreFormationTD ;
    d2rq:propertyDefinitionComment "name of the oldest lithostratigraphic unit penetrated by the wellbore. in most wellbores this is formation or group at total depth. may differ from formation or group at td for example in wellbores drilled with high deviation or through faults. examples of legal values: amundsen fm, balder fm, basement, blodøks fm, bryne fm, burton fm, cook fm, drake fm, draupne fm, ekofisk fm, dunlin gp." ;
    d2rq:propertyDefinitionLabel "oldest penetrated formation" ;
    d2rq:refersToClassMap map:ex3 .

map:wellbore_exploration_all__wlbFormationWithHc1
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:join "wellbore_exploration_all.wlbformationwithhc1 => wellbore_formation_top.lsuname" ;
    d2rq:property npdv:wellboreFormationHcLevel1 ;
    d2rq:propertyDefinitionComment "name of lithostartigraphic unit, 1st level, where hydrocarbons were encountered. examples of legal values: basement, cook fm, ekofisk fm, heimdal fm, sandnes fm, sognefjord fm, tarbert fm, brent gp. see also npd bulletins." ;
    d2rq:propertyDefinitionLabel "1st level with hc, formation" ;
    d2rq:refersToClassMap map:ex3 .

map:wellbore_exploration_all__wlbFormationWithHc2
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:join "wellbore_exploration_all.wlbformationwithhc2 => wellbore_formation_top.lsuname" ;
    d2rq:property npdv:wellboreFormationHcLevel2 ;
    d2rq:propertyDefinitionComment "name of lithostartigraphic unit, 2nd level, where hydrocarbons were encountered. examples of legal values: basement, cook fm, ekofisk fm, heimdal fm, sandnes fm, sognefjord fm, tarbert fm, brent gp." ;
    d2rq:propertyDefinitionLabel "2nd level with hc, formation" ;
    d2rq:refersToClassMap map:ex3 .

map:wellbore_exploration_all__wlbFormationWithHc3
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:join "wellbore_exploration_all.wlbformationwithhc3 => wellbore_formation_top.lsuname" ;
    d2rq:property npdv:wellboreFormationHcLevel3 ;
    d2rq:propertyDefinitionComment "name of lithostartigraphic unit, 3rd level, where hydrocarbons were encountered. examples of legal values: basement, cook fm, ekofisk fm, heimdal fm, sandnes fm, sognefjord fm, tarbert fm, brent gp." ;
    d2rq:propertyDefinitionLabel "3rd level with hc, formation" ;
    d2rq:refersToClassMap map:ex3 .

map:wellbore_exploration_all__wlbGeodeticDatum
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbgeodeticdatum" ;

    d2rq:datatype xsd:string ;
    d2rq:property npdv:geodeticDatum ;
    d2rq:propertyDefinitionComment "reference system for coordinates. example of legal values: ed50." ;
    d2rq:propertyDefinitionLabel "geodetic datum" .

map:wellbore_exploration_all__wlbKellyBushElevation
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbkellybushelevation" ;

    d2rq:datatype xsd:decimal ;
    d2rq:property npdv:wellboreKellyBushElevation ;
    d2rq:propertyDefinitionComment "elevation of the rotary kelly bushing (rkb) above mean sea level." ;
    d2rq:propertyDefinitionLabel "kelly bushing elevation [m]" .

map:wellbore_exploration_all__wlbLicensingActivity
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlblicensingactivity" ;

    d2rq:datatype xsd:string ;
    d2rq:property npdv:wellboreLicensingActivity ;
    d2rq:propertyDefinitionComment "name of the licensing activity the production licence the wellbore was drilled in, was awarded in." ;
    d2rq:propertyDefinitionLabel "licensing activity awarded in" .

map:wellbore_exploration_all__wlbMainArea
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:property npdv:mainAreaLocation ;
    d2rq:propertyDefinitionComment "name of the area on the norwegian continental shelf where the wellbore is located. legal values: barents sea, norwegian sea, north sea." ;
    d2rq:propertyDefinitionLabel "main area" ;
    d2rq:uriColumn "wellbore_exploration_all.wlbmainarea" .

map:wellbore_exploration_all__wlbMaxInclation
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbmaxinclation" ;

    d2rq:datatype xsd:decimal ;
    d2rq:property npdv:wellboreMaxInclation ;
    d2rq:propertyDefinitionComment "maximum deviation, in degrees, from a vertical well path." ;
    d2rq:propertyDefinitionLabel "maximum inclination [°]" .

map:wellbore_exploration_all__wlbMultilateral
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbmultilateral" ;

    d2rq:datatype xsd:boolean ;
    d2rq:property npdv:isMultilateral ;
    d2rq:propertyDefinitionComment "indicator telling if the parent well is multilateral, meaning it has more than one branch radiating from the main borehole. example of legal values: yes, no. see also npd guidelines for designation of wells and wellbores." ;
    d2rq:propertyDefinitionLabel "multilateral" .

map:wellbore_exploration_all__wlbNamePart1
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbnamepart1" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:wellboreNamePart1 ;
    d2rq:propertyDefinitionComment "part 1 of the wellbore name. tells quadrant number on the norwegian continental shelf the wellbore was drilled in. based on npd guidelines for designation of wells and wellbores." ;
    d2rq:propertyDefinitionLabel "wellbore name, part 1" .

map:wellbore_exploration_all__wlbNamePart2
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbnamepart2" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:wellboreNamePart2 ;
    d2rq:propertyDefinitionComment "part 2 of the wellbore name. tells the block number the wellbore was drilled in. based on npd guidelines for designation of wells and wellbores." ;
    d2rq:propertyDefinitionLabel "wellbore name, part 2" .

map:wellbore_exploration_all__wlbNamePart3
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbnamepart3" ;

    d2rq:datatype xsd:string ;
    d2rq:property npdv:wellboreNamePart3 ;
    d2rq:propertyDefinitionComment "part 3 of the wellbore name. tells the name of the installation the wellbore was drilled from. not used for exploration wellbores. based on npd guidelines for designation of wells and wellbores." ;
    d2rq:propertyDefinitionLabel "wellbore name, part 3" .

map:wellbore_exploration_all__wlbNamePart4
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbnamepart4" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:wellboreNamePart4 ;
    d2rq:propertyDefinitionComment "part 4 of the wellbore name. serial number for the wellbore. based on npd guidelines for designation of wells and wellbores." ;
    d2rq:propertyDefinitionLabel "wellbore name, part 4" .

map:wellbore_exploration_all__wlbNamePart5
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbnamepart5" ;

    d2rq:datatype xsd:string ;
    d2rq:property npdv:wellboreNamePart5 ;
    d2rq:propertyDefinitionComment "part 5 of the wellbore name. used to indicate exploration wells planned deviated (s), sidetracks (a, b,...), re-entries (r) or planned multilaterals (y). based on npd guidelines for designation of wells and wellbores." ;
    d2rq:propertyDefinitionLabel "wellbore name, part 5" .

map:wellbore_exploration_all__wlbNamePart6
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbnamepart6" ;

    d2rq:datatype xsd:string ;
    d2rq:property npdv:wellboreNamePart6 ;
    d2rq:propertyDefinitionComment "part 6 of the wellbore name. serial number of re-entries or serial number of the well tracks in multilatrals. based on npd guidelines for designation of wells and wellbores." ;
    d2rq:propertyDefinitionLabel "wellbore name, part 6" .

map:wellbore_exploration_all__wlbNpdidWellbore
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbnpdidwellbore" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:idNPD ;
    d2rq:propertyDefinitionComment "npd's unique id for the wellbore." ;
    d2rq:propertyDefinitionLabel "npdid wellbore" .

map:wellbore_exploration_all__wlbNpdidWellboreReclass
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:condition "wellbore_exploration_all.wlbnpdidwellborereclass <> 0" ;
    d2rq:property npdv:reclassedFromWellbore ;
    d2rq:propertyDefinitionComment "npd's unique id for the wellbore this wellbore was reclassified from." ;
    d2rq:propertyDefinitionLabel "npdid wellbore reclassified from" ;
    d2rq:uriPattern "http://sws.ifi.uio.no/data/npd-v2/wellbore/@@wellbore_exploration_all.wlbnpdidwellborereclass@@" .

