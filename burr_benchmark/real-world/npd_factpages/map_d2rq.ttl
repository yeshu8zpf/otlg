map:Adatabase a d2rq:Database;
       d2rq:jdbcDriver "org.postgresql.Driver";
       d2rq:jdbcDSN "jdbc:postgresql://localhost:5432/npd";
       d2rq:username "lukaslaskowski";
       d2rq:textColumn "apaareagross.apaareageometryewkt", "apaareanet.apaareanetgeometrywkt", "baaarea.baaareageometrywkt", "dscarea.flddscareageometrywkt_ed50", "fclpoint.fclpointgeometrywkt", "fldarea.flddscareageometrywkt_ed50", "pipline.piplinegeometrywkt", "prlarea.prlareageometrywkt", "prlareasplitbyblock.prlareageometrywkt", "seaarea.seapolygeometrywkt", "seamultiline.seamultilinegeometrywkt", "wlbpoint.wlbpointgeometrywkt" ;
       jdbc:keepAlive "3600";                          # sends noop-query every 3600 seconds
       .

