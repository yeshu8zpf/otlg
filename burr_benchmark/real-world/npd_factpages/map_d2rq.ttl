    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbdrillpermit" ;

    d2rq:datatype xsd:string ;
    d2rq:property npdv:drillPermit ;
    d2rq:propertyDefinitionComment "the drilling permit number together with the version of the drilling permit as stated in the drilling permit granted by the npd." ;
    d2rq:propertyDefinitionLabel "drill permit" .

map:wellbore_exploration_all__wlbDrillingDays
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbdrillingdays" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:wellboreDrillingDays ;
    d2rq:propertyDefinitionComment "number of days from wellbore entry to wellbore completion." ;
    d2rq:propertyDefinitionLabel "drilling days" .

map:wellbore_exploration_all__wlbDrillingOperator__ref
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:join "wellbore_exploration_all.wlbdrillingoperator => company.cmplongname" ;
    d2rq:property npdv:drillingOperatorCompany ;
