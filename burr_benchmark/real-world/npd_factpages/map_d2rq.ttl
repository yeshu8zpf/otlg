    d2rq:propertyDefinitionLabel "multilateral" .

map:wellbore_development_all__wlbNamePart1
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_development_all ;
    d2rq:column "wellbore_development_all.wlbnamepart1" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:wellboreNamePart1 ;
    d2rq:propertyDefinitionComment "part 1 of the wellbore name. tells quadrant number on the norwegian continental shelf the wellbore was drilled in. based on npd guidelines for designation of wells and wellbores." ;
    d2rq:propertyDefinitionLabel "wellbore name, part 1" .

map:wellbore_development_all__wlbNamePart2
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_development_all ;
    d2rq:column "wellbore_development_all.wlbnamepart2" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:wellboreNamePart2 ;
