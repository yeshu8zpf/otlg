    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbreentry" ;

    d2rq:datatype xsd:boolean ;
    d2rq:property npdv:isReentryWellbore ;
    d2rq:propertyDefinitionComment "status whether the wellbore has been re-entered (yes) or not(no). when counting number of wellbores on the norwegian continental shelf, only those not reentered are counted (no)." ;
    d2rq:propertyDefinitionLabel "reentry" .

map:wellbore_exploration_all__wlbReentryExplorationActivity
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbreentryexplorationactivity" ;

    d2rq:datatype xsd:string ;
    d2rq:property npdv:wellboreReentryExplorationActivity ;
    d2rq:propertyDefinitionComment "reason for reentry of the wellbore. only relevant for exploration wellbores. example of legal values: drilling, drilling/plugging, logging, plugging, testing, testing/plugging." ;
    d2rq:propertyDefinitionLabel "reentry activity" .

map:wellbore_exploration_all__wlbSeismicLocation
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbseismiclocation" ;

    d2rq:datatype xsd:string ;
    d2rq:property npdv:wellboreSeismicLocation ;
    d2rq:propertyDefinitionComment "position of wellbore on seismic survey lines. sp: shotpoint." ;
    d2rq:propertyDefinitionLabel "seismic location" .

map:wellbore_exploration_all__wlbStatus
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:wellbore_exploration_all ;
    d2rq:column "wellbore_exploration_all.wlbstatus" ;

    d2rq:property npdv:status ;
    d2rq:propertyDefinitionComment "present wellbore status. legal values: p&a (plugged and abandoned), re-class to dev (reclassified to development well), junked (abandoned due to technical problems), suspended (temporarily abandoned), susp.reentered later (completed before planned depth (td) , will be re-entered later)." ;
    d2rq:propertyDefinitionLabel "status" .

map:wellbore_exploration_all__wlbStatus__Class
    a d2rq:PropertyBridge ;
