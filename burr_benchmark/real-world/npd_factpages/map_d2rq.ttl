    d2rq:datatype xsd:string ;
    d2rq:property npdv:wellboreNamePart3 ;
    d2rq:propertyDefinitionComment "part 3 of the wellbore name. tells the name of the installation the wellbore was drilled from. not used for exploration wellbores. based on npd guidelines for designation of wells and wellbores." ;
    d2rq:propertyDefinitionLabel "wellbore name, part 3" .

map:wellbore_shallow_all__wlbNamePart4
    a d2rq:PropertyBridge ;
