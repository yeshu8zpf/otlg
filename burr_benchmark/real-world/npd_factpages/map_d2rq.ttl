    d2rq:property npdv:codeNS ;
    d2rq:propertyDefinitionComment "indicator whcih tells if the coordinate of the wellhead is on the nothern or southern hemisphere. legal values: n, s." ;
    d2rq:propertyDefinitionLabel "ns code" .

