map:apaAreaGross
    a d2rq:ClassMap ;
    rdfs:label "npdv:mainarea__apaareagross" ;
    d2rq:class npdv:MainArea ;
    d2rq:classDefinitionLabel "updated apa (awards in predefined areas) gross areas." ;
    d2rq:dataStorage map:Adatabase ;
    d2rq:uriPattern "http://sws.ifi.uio.no/data/npd-v2/mainarea/@@apaareagross.apaareagross_id@@" .

map:apaAreaGross__apaAreaGeometryEWKT
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:apaAreaGross ;
    d2rq:property geos:asWKT ;
    d2rq:sqlExpression "cast(astext(apaareagross.apaareageometryewkt) as char)" .

map:apaAreaGross__apaAreaGeometry_KML_WGS84
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:apaAreaGross ;
    d2rq:column "apaareagross.apaareageometry_kml_wgs84" ;

    d2rq:datatype xsd:string ;
    d2rq:property geos:hasSerialization .

map:apaAreaGross__apaMap_no
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:apaAreaGross ;
    d2rq:column "apaareagross.apamap_no" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:mapNo .

map:apaAreaNet
    a d2rq:ClassMap ;
    rdfs:label "npdv:awardarea__apaareanet" ;
    d2rq:class npdv:AwardArea ;
    d2rq:classDefinitionLabel "apa (awards in predefined areas) net areas." ;
    d2rq:dataStorage map:Adatabase ;
    d2rq:uriPattern "http://sws.ifi.uio.no/data/npd-v2/quadrant/@@apaareanet.qdrname@@/block/@@apaareanet.blkname@@/award/@@apaareanet.prvname@@/area/@@apaareanet.apaareanet_id@@" .

map:apaAreaNet__apaAreaNetGeometryWKT
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:apaAreaNet ;
    d2rq:property geos:asWKT ;
    d2rq:sqlExpression "cast(astext(apaareanet.apaareanetgeometrywkt) as char)" .

map:apaAreaNet__apaAreaType
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:apaAreaNet ;
    d2rq:column "apaareanet.apaareatype" ;

    d2rq:datatype xsd:boolean ;
    d2rq:property npdv:isStratigraphical .

map:apaAreaNet__blkId
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:apaAreaNet ;
    d2rq:column "apaareanet.blkid" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:blockId .

map:apaAreaNet__blkLabel
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:apaAreaNet ;
    d2rq:property npdv:blockLocation ;
    d2rq:uriPattern "http://sws.ifi.uio.no/data/npd-v2/block/@@apaareanet.blklabel@@" .

map:apaAreaNet__prvName
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:apaAreaNet ;
    d2rq:property npdv:provinceLocation ;
    d2rq:uriPattern "http://sws.ifi.uio.no/data/npd-v2/province/@@apaareanet.prvname@@" .

map:apaAreaNet__qdrName
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:apaAreaNet ;
    d2rq:property npdv:quadrantLocation ;
    d2rq:uriPattern "http://sws.ifi.uio.no/data/npd-v2/quadrant/@@apaareanet.qdrname@@" .

map:apaAreaNet__urlNPD
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:apaAreaNet ;
    d2rq:property npdv:npdPageURL ;
    d2rq:uriColumn "apaareanet.urlnpd" .

map:baaArea
    a d2rq:ClassMap ;
    rdfs:label "npdv:baaarea__baaarea" ;
    d2rq:class npdv:BAAArea ;
    d2rq:classDefinitionLabel "business arrangement areas with complete history for each area." ;
    d2rq:dataStorage map:Adatabase ;
    d2rq:uriPattern "http://sws.ifi.uio.no/data/npd-v2/baa/@@baaarea.baanpdidbsnsarrarea@@/polygon/@@baaarea.baanpdidbsnsarrareapoly@@" .

map:baaArea__baaAreaGeometryWKT
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:baaArea ;
    d2rq:property geos:asWKT ;
    d2rq:sqlExpression "cast(astext(baaarea.baaareageometrywkt) as char)" .

map:baaArea__baaAreaPolyActive
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:baaArea ;
    d2rq:column "baaarea.baaareapolyactive" ;

    d2rq:datatype xsd:boolean ;
    d2rq:property npdv:isActive .

map:baaArea__baaAreaPolyDateValidFrom
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:baaArea ;
    d2rq:column "baaarea.baaareapolydatevalidfrom" ;
    d2rq:condition "baaarea.baaareapolydatevalidfrom <> ''", "baaarea.baaareapolydatevalidfrom <> '9999-12-31t00:00:00'" ;
    d2rq:datatype xsd:dateTime ;
    d2rq:property npdv:dateBaaAreaValidFrom ;
    d2rq:propertyDefinitionComment "the date the polygon area is valid from" ;
    d2rq:propertyDefinitionLabel "date valid from" .

map:baaArea__baaAreaPolyDateValidTo
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:baaArea ;
    d2rq:column "baaarea.baaareapolydatevalidto" ;
    d2rq:condition "baaarea.baaareapolydatevalidto <> ''", "baaarea.baaareapolydatevalidto <> '9999-12-31t00:00:00'" ;
    d2rq:datatype xsd:dateTime ;
    d2rq:property npdv:dateBaaAreaValidTo ;
    d2rq:propertyDefinitionComment "the date the polygon area is valid to" ;
    d2rq:propertyDefinitionLabel "date valid to" .

map:baaArea__baaNpdidBsnsArrAreaPoly
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:baaArea ;
    d2rq:column "baaarea.baanpdidbsnsarrareapoly" ;

    d2rq:datatype xsd:integer ;
    d2rq:property npdv:idNPD .

map:baaArea__baaNpdidBsnsArrArea__ref
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:baaArea ;
    d2rq:join "baaarea.baanpdidbsnsarrarea => bsns_arr_area.baanpdidbsnsarrarea" ;
    d2rq:property npdv:isGeometryOfFeature ;
    d2rq:refersToClassMap map:bsns_arr_area .

map:bsns_arr_area
    a d2rq:ClassMap ;
    rdfs:label "npdv:baa__bsns_arr_area" ;
    d2rq:class npdv:BAA ;
    d2rq:classDefinitionComment "business arrangement areas on the norwegian continental shelf, with complete history for each business area." ;
    d2rq:classDefinitionLabel "business arrangement area" ;
    d2rq:dataStorage map:Adatabase ;
    d2rq:uriPattern "http://sws.ifi.uio.no/data/npd-v2/baa/@@bsns_arr_area.baanpdidbsnsarrarea@@" .

map:bsns_arr_area__baaDateApproved
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:bsns_arr_area ;
    d2rq:column "bsns_arr_area.baadateapproved" ;
    d2rq:condition "bsns_arr_area.baadateapproved <> ''", "bsns_arr_area.baadateapproved <> '9999-12-31t00:00:00'" ;
    d2rq:datatype xsd:dateTime ;
    d2rq:property npdv:dateApproved ;
    d2rq:propertyDefinitionComment "the date the agreement for the business arrangement area was approved by the norwegian authorities." ;
    d2rq:propertyDefinitionLabel "date approved" .

map:bsns_arr_area__baaDateUpdated
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:bsns_arr_area ;
    d2rq:column "bsns_arr_area.baadateupdated" ;
    d2rq:condition "bsns_arr_area.baadateupdated <> ''", "bsns_arr_area.baadateupdated <> '9999-12-31t00:00:00'" ;
    d2rq:datatype xsd:dateTime ;
    d2rq:property npdv:dateUpdated ;
    d2rq:propertyDefinitionComment "date when information about this business agreement area was last updated or inserted for the first time.the date will only be changed if the data in the 'main level' in the tab 'baa' will be changed." ;
    d2rq:propertyDefinitionLabel "date main level updated" .

map:bsns_arr_area__baaDateUpdatedMax
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:bsns_arr_area ;
    d2rq:column "bsns_arr_area.baadateupdatedmax" ;
    d2rq:condition "bsns_arr_area.baadateupdatedmax <> ''", "bsns_arr_area.baadateupdatedmax <> '9999-12-31t00:00:00'" ;
    d2rq:datatype xsd:dateTime ;
    d2rq:property npdv:dateUpdatedMax ;
    d2rq:propertyDefinitionComment "date when any information about this business area was last updated or inserted for the first time. the date also will bli change if some of the data in the 'sub levels' in the tab 'baa' will be changed." ;
    d2rq:propertyDefinitionLabel "date all updated" .

map:bsns_arr_area__baaDateValidFrom
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:bsns_arr_area ;
    d2rq:column "bsns_arr_area.baadatevalidfrom" ;
    d2rq:condition "bsns_arr_area.baadatevalidfrom <> ''", "bsns_arr_area.baadatevalidfrom <> '9999-12-31t00:00:00'" ;
    d2rq:datatype xsd:dateTime ;
    d2rq:property npdv:dateBaaValidFrom ;
    d2rq:propertyDefinitionComment "the date the agreement for the business arrangement area is valid from, according to the approval of the norwegian authorities." ;
    d2rq:propertyDefinitionLabel "date valid from" .

map:bsns_arr_area__baaDateValidTo
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:bsns_arr_area ;
    d2rq:column "bsns_arr_area.baadatevalidto" ;
    d2rq:condition "bsns_arr_area.baadatevalidto <> ''", "bsns_arr_area.baadatevalidto <> '9999-12-31t00:00:00'" ;
    d2rq:datatype xsd:dateTime ;
    d2rq:property npdv:dateBaaValidTo ;
    d2rq:propertyDefinitionComment "the date the agreement for the business arrangement area is valid to, according to the approval of the norwegian authorities." ;
    d2rq:propertyDefinitionLabel "date valid to" .

map:bsns_arr_area__baaFactMapUrl
    a d2rq:PropertyBridge ;
    d2rq:belongsToClassMap map:bsns_arr_area ;
    d2rq:property npdv:factMapURL ;
    d2rq:propertyDefinitionComment "url to the business arrangement area's factmap on the npd's factweb" ;
