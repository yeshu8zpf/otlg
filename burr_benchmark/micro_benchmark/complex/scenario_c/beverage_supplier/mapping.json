{
    "classes": [
        {
            "id": "supplier/@@supplier.id@@",
            "class": "Supplier",
            "name": "Supplier"
        },
        {
            "id": "beverage/@@beverage.id@@",
            "class": "Beverage"
        },
        {
            "id": "Caffeine",
            "class": "Ingredient",
            "name": "IngredientCaffeine"
        },
        {
            "id": "Sugar",
            "class": "Ingredient",
            "name": "IngredientSugar"
        },
        {
            "id": "Alcohol",
            "class": "Ingredient",
            "name": "IngredientAlcohol"
        },
        {
            "id": "Dairy",
            "class": "Ingredient",
            "name": "IngredientDairy"
        },
        {
            "id": "Gluten",
            "class": "Ingredient",
            "name": "IngredientGluten"
        },
        {
            "id": "Nuts",
            "class": "Ingredient",
            "name": "IngredientNuts"
        }
    ],
    "object_properties": [
        {
            "property": "supplies",
            "belongsToClassMap": "Supplier",
            "refersToClass": "Beverage",
            "join": [
                "beverage_supplier.supplier_id = supplier.id",
                "beverage_supplier.beverage_id = beverage.id"
            ]
        },
        {
            "property": "contains",
            "belongsToClass": "Beverage",
            "refersToClassMap": "IngredientAlcohol",
            "condition": "beverage.contains_alcohol = 'True'"
        },
        {
            "property": "contains",
            "belongsToClass": "Beverage",
            "refersToClassMap": "IngredientCaffeine",
            "condition": "beverage.contains_caffeine = 'True'"
        },
        {
            "property": "contains",
            "belongsToClass": "Beverage",
            "refersToClassMap": "IngredientSugar",
            "condition": "beverage.contains_sugar = 'True'"
        },
        {
            "property": "contains",
            "belongsToClass": "Beverage",
            "refersToClassMap": "IngredientDairy",
            "condition": "beverage.contains_dairy = 'True'"
        },
        {
            "property": "contains",
            "belongsToClass": "Beverage",
            "refersToClassMap": "IngredientGluten",
            "condition": "beverage.contains_gluten = 'True'"
        },
        {
            "property": "contains",
            "belongsToClass": "Beverage",
            "refersToClassMap": "IngredientNuts",
            "condition": "beverage.contains_nuts = 'True'"
        }
    ],
    "data_properties": [
        {
            "property": "name",
            "belongsToClass": "Beverage",
            "type": "string",
            "column": "beverage.name"
        },
        {
            "property": "name",
            "belongsToClassMap": "Supplier",
            "type": "string",
            "column": "supplier.name"
        },
        {
            "property": "street",
            "belongsToClassMap": "Supplier",
            "type": "string",
            "sqlExpression": "split_part(supplier.address, ',', 1)"
        },
        {
            "property": "city",
            "belongsToClassMap": "Supplier",
            "type": "string",
            "sqlExpression": "split_part(supplier.address, ',', 2)"
        },
        {
            "property": "state",
            "belongsToClassMap": "Supplier",
            "type": "string",
            "sqlExpression": "split_part(supplier.address, ',', 3)"
        },
        {
            "property": "country",
            "belongsToClassMap": "Supplier",
            "type": "string",
            "sqlExpression": "split_part(supplier.address, ',', 4)"
        }
    ]
}