{
    "classes": [
        {
            "id": "hotel/@@hotel.id@@",
            "class": "Hotel",
            "name": "Hotel"
        },
        {
            "id": "room/@@room.hotel_id@@/@@room.room_number@@",
            "class": "Room",
            "name": "Room"
        }
    ],
    "object_properties": [
        {
            "property": "rooms",
            "belongsToClassMap": "Hotel",
            "refersToClassMap": "Room",
            "join": [
                "hotel.id = room.hotel_id"
            ]
        }
    ],
    "data_properties": [
        {
            "property": "name",
            "belongsToClassMap": "Hotel",
            "type": "string",
            "column": "hotel.name"
        },
        {
            "property": "room_number",
            "belongsToClassMap": "Room",
            "type": "string",
            "column": "room.room_number"
        },
        {
            "property": "bed_number",
            "belongsToClassMap": "Room",
            "type": "integer",
            "column": "room.bed_number"
        },
        {
            "property": "street",
            "belongsToClassMap": "Hotel",
            "type": "string",
            "sqlExpression": "split_part(hotel.address, ',', 1)"
        },
        {
            "property": "city",
            "belongsToClassMap": "Hotel",
            "type": "string",
            "sqlExpression": "split_part(hotel.address, ',', 2)"
        },
        {
            "property": "state",
            "belongsToClassMap": "Hotel",
            "type": "string",
            "sqlExpression": "split_part(hotel.address, ',', 3)"
        },
        {
            "property": "country",
            "belongsToClassMap": "Hotel",
            "type": "string",
            "sqlExpression": "split_part(hotel.address, ',', 4)"
        },
        {
            "property": "building",
            "belongsToClassMap": "Room",
            "type": "string",
            "sqlExpression": "split_part(room.location, ',', 1)"
        },
        {
            "property": "wing",
            "belongsToClassMap": "Room",
            "type": "string",
            "sqlExpression": "split_part(room.location, ',', 2)"
        },
        {
            "property": "floor",
            "belongsToClassMap": "Room",
            "type": "string",
            "sqlExpression": "split_part(room.location, ',', 3)"
        },
        {
            "property": "corridor",
            "belongsToClassMap": "Room",
            "type": "string",
            "sqlExpression": "split_part(room.location, ',', 4)"
        }
    ]
}